# Postgres connection string (Neon/Supabase). Falls back to local SQLite if unset.
DATABASE_URL=postgresql://user:password@host/dbname

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://somromscan-mrv.vercel.app,http://localhost:3000
